generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MuscleGroup {
  PECHO
  BICEPS
  TRICEPS
  ESPALDA
  HOMBROS
  PIERNAS
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  age          Int
  createdAt    DateTime     @default(now())
  exercises    Exercise[]
  routine      RoutineDay[]
}

model Exercise {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  muscleGroup MuscleGroup
  notes       String?
  createdAt   DateTime     @default(now())
  sets        WorkoutSet[]

  @@index([userId, muscleGroup])
}

model WorkoutSet {
  id          String   @id @default(cuid())
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  weight      Float
  reps        Int
  sets        Int      @default(1)
  performedAt DateTime @default(now())
  notes       String?

  @@index([exerciseId, performedAt])
}

model RoutineDay {
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  muscleGroups MuscleGroup[]
  updatedAt    DateTime      @updatedAt

  @@id([userId, dayOfWeek])
}
